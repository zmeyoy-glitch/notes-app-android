<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NotesApp" parent="android:Theme.Material.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        
        <!-- Стилизация текста -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:hintTextColor">@color/hint_text</item>
        
        <!-- Стилизация кнопок -->
        <item name="android:buttonStyle">@style/Widget.App.Button</item>
    </style>

    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/button_text</item>
        <item name="backgroundTint">@color/button_background</item>
        <item name="cornerRadius">8dp</item>
        <item name="elevation">2dp</item>
    </style>

    <!-- Стилизация EditText -->
    <style name="Widget.App.EditText" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary_dark</item>
        <item name="hintTextColor">@color/hint_text</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Стилизация TextView -->
    <style name="Widget.App.TextView" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
    </style>
</resources>