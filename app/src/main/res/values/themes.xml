<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NotesApp" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Основной цвет -->
        <item name="colorPrimary">#007AFF</item>
        <item name="colorPrimaryVariant">#0056CC</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        
        <!-- Акцентный цвет -->
        <item name="colorSecondary">#FF2D80</item>
        <item name="colorSecondaryVariant">#C41F73</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        
        <!-- Цвета текста -->
        <item name="android:textColorPrimary">#333333</item>
        <item name="android:textColorSecondary">#666666</item>
        
        <!-- Фон -->
        <item name="colorBackground">#F8F9FA</item>
        <item name="colorSurface">#FFFFFF</item>
    </style>
    
    <!-- Стиль для кнопок -->
    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="android:textColor">#FFFFFF</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">8dp</item>
    </style>
    
    <!-- Стиль для текстовых полей -->
    <style name="Widget.App.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/text_primary</item>
    </style>
    
    <!-- Стиль для карточек -->
    <style name="Widget.App.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="backgroundTint">@color/white</item>
    </style>
</resources>